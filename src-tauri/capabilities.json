{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "websocket:default",
    "dialog:default",
    "window:allow-set-size",
    "window:allow-set-position",
    "window:allow-show",
    "window:allow-hide"
  ]
}
